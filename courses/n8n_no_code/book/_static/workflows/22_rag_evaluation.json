      {
       "id": "a1",
       "name": "case_passed",
       "type": "number",
       "value": "={{ $('Run test cases').item.json.should_refuse == 'yes'  ? ( $json.output.toLowerCase().includes(\"i don't have that information\") ? 1 : 0 )  : ( ( !$json.output.toLowerCase().includes(\"i don't have that information\") )      && ( !$('Run test cases').item.json.expected_contains           || $json.output.toLowerCase().includes(($('Run test cases').item.json.expected_contains + '').toLowerCase()) )      ? 1 : 0 ) }}"
      }
     ]
    },
    "options": {}
   },
