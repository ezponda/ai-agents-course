      {
       "id": "r1",
       "name": "retrieval_hit",
       "type": "number",
       "value": "={{ $('Run test cases').item.json.expected_retrieval_contains  ? ( JSON.stringify($json.data).toLowerCase().includes(($('Run test cases').item.json.expected_retrieval_contains + '').toLowerCase()) ? 1 : 0 )  : null }}"
      }
     ]
