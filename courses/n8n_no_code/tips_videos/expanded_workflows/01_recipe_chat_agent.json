        "name": "Recipe Search",
        "description": "Search for common recipes by name in TheMealDB. Search terms MUST be in English and simple (e.g. 'chicken', 'lasagna', 'beef stew'). If the dish is regional or not found, use Google Search instead. NEVER pass user messages like ages or allergies — only food terms.",
        "method": "GET",
        "url": "https://www.themealdb.com/api/json/v1/1/search.php?s={search_term}",
        "placeholderDefinitions": {
          "values": [
            {
              "name": "search_term",
              "description": "The recipe name to search for in English. Only food terms like 'chicken', 'lasagna', 'pasta'. Never ages, allergies or user messages."
            }
          ]
        },
        "optimizeResponse": true
      },
